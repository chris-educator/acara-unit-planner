# Primary unit generation — Anthropic (recommended)
ANTHROPIC_API_KEY=
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# Ask the Assistant (Gemini Flash)
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Output token caps — prevents runaway Gemini bills
GEMINI_MAX_OUTPUT_TOKENS_UNIT=8192
GEMINI_MAX_OUTPUT_TOKENS_REFINE=1024
GEMINI_MAX_OUTPUT_TOKENS_ASSISTANT=512
MAX_ASSISTANT_MESSAGES=40
MAX_ASSISTANT_MESSAGE_CHARS=4000
# MAX_REQUEST_BYTES=15000000

# Rate limits (on by default)
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_GENERATE_MAX=24
# RATE_LIMIT_GENERATE_WINDOW=3600
# RATE_LIMIT_ASSISTANT_MAX=40
# RATE_LIMIT_ASSISTANT_WINDOW=300
# RATE_LIMIT_EXPORT_MAX=60
# RATE_LIMIT_EXPORT_WINDOW=3600

# Optional error monitoring
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=

# Client build (Vite)
# VITE_SITE_URL=https://planner.appstax.ai
# VITE_SENTRY_DSN=

# --- EdStack shared wallet (recommended for production) ---
# BILLING_ENABLED=true
# AUTH_SECRET=<shared>
# EDSTACK_BILLING_URL=https://account.appstax.ai
# EDSTACK_BILLING_SERVICE_SECRET=<shared>
# EDSTACK_APP_ID=acara-unit-planner
# SESSION_COOKIE_DOMAIN=.appstax.ai
# AUTH_COOKIE_SECURE=true
# APP_PUBLIC_URL=https://planner.appstax.ai

# Email verification (central SMTP on account service when using shared wallet)
# EMAIL_VERIFICATION_ENABLED=true

# Google sign-in (optional)
# GOOGLE_OAUTH_CLIENT_ID=....apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=...
